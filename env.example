# Dozzle Production Configuration
# Copy this file to .env and customize as needed

# Port to expose Dozzle on
DOZZLE_PORT=8080

# Log level: debug, info, warn, error
DOZZLE_LEVEL=info

# Disable analytics (1 = disabled, 0 = enabled)
DOZZLE_NO_ANALYTICS=1

# Custom hostname display (optional)
DOZZLE_HOSTNAME=

# Container filter (optional) - e.g., "name=myapp" or "label=env=prod"
DOZZLE_FILTER=

# Authentication provider: none, simple, forward-proxy
# For 'simple' auth, create data/users.yml with user credentials
DOZZLE_AUTH_PROVIDER=none

# Base URL path (useful for reverse proxy setups) - e.g., /logs
DOZZLE_BASE=/
